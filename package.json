{
  "name": "doubao-plus",
  "version": "0.1.0",
  "description": "An all-in-one enhancement suite for Doubao AI - folder management, prompt library, timeline navigation, and more.",
  "type": "module",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "nodemon --config nodemon.chrome.json --exec \"npm run build:chrome\"",
    "dev:chrome": "nodemon --config nodemon.chrome.json --exec \"npm run build:chrome\"",
    "dev:firefox": "nodemon --config nodemon.firefox.json --exec \"npm run build:firefox\"",
    "build": "npm run build:chrome",
    "build:chrome": "vite build --config vite.config.chrome.ts",
    "build:firefox": "vite build --config vite.config.firefox.ts",
    "build:all": "npm run build:chrome ; npm run build:firefox",
    "package": "node scripts/package-crx.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.0.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "^0.0.268",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "archiver": "^7.0.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^15.0.0",
    "nodemon": "^3.0.3",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.0",
    "vite": "^5.1.0",
    "vitest": "^1.2.0"
  }
}
